@{
}

<table class="table table-bordered">
    <tr>
        <th>Name</th>
        <th>Id</th>
        <th>Cgpa</th>
        <th>Department</th>
        <th>Courses Count</th>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Id</td>
            <td>@item.Cgpa</td>
            <td>@item.Dept.Name</td>
            <td>@item.Dept.Courses.Count</td>
        </tr>
    }
</table>