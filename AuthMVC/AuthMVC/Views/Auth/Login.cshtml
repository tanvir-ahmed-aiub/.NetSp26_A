@{
}
@if (TempData["Msg"] != null)
{
    <span class="alert @TempData["Class"]">@TempData["Msg"]</span>
}
<form method="post">
    <h2>Login</h2>
    <div class="col-md-6 align-content-center">
        <input type="text" placeholder="Username" name="Uname" class="form-control" />
        <span class="text-danger">@Html.ValidationMessage("Username")</span>
        <input type="password" placeholder="Password" name="Pass" class="form-control" />
        <span class="text-danger">@Html.ValidationMessage("Password")</span>
        <input type="submit" value="Register" class="btn  btn-primary" />
    </div>
</form>